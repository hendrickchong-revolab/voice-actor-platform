generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---

enum UserRole {
  AGENT
  MANAGER
  ADMIN
}

enum RecordingStatus {
  PENDING
  PROCESSING
  APPROVED
  REJECTED
  FLAGGED
}

enum ScriptStatus {
  AVAILABLE
  LOCKED
  COMPLETED
}

// --- NEXTAUTH MODELS (v4 Prisma Adapter) ---

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?
  name          String?
  username      String?   @unique
  firstName     String?
  lastName      String?
  image         String?
  emailVerified DateTime?

  role          UserRole  @default(AGENT)
  languages     String[]  @default([])

  // Agent Stats
  meritScore    Float     @default(100.0)
  walletBalance Float     @default(0.0)

  accounts      Account[]
  sessions      Session[]

  // Domain
  recordings    Recording[]
  lockedScripts ScriptLine[] @relation("ScriptLocks")
  projectAssignments ProjectAssignment[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- DOMAIN MODELS ---

model Project {
  id              String   @id @default(cuid())
  title           String
  description     String?
  language        String?

  targetMos       Float    @default(3.5)
  nisqaMinScore   Float    @default(3.5)
  maxNoiseFloorDb Float    @default(-40.0)
  maxWer          Float    @default(0.15)

  payPerLine      Float    @default(0.50)
  isActive        Boolean  @default(true)

  scripts         ScriptLine[]
  assignments     ProjectAssignment[]
  createdAt       DateTime @default(now())
}

model ProjectAssignment {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@index([projectId])
}

model ScriptLine {
  id             String       @id @default(cuid())
  projectId      String
  text           String
  context        String?

  status         ScriptStatus @default(AVAILABLE)

  lockedByUserId String?
  lockedAt       DateTime?

  project        Project      @relation(fields: [projectId], references: [id])
  lockedBy       User?        @relation("ScriptLocks", fields: [lockedByUserId], references: [id], onDelete: SetNull)
  recordings     Recording[]

  @@index([projectId, status])
  @@index([lockedByUserId, lockedAt])
}

model Recording {
  id          String          @id @default(cuid())

  userId      String
  scriptId    String

  audioUrl    String
  audioSha256 String?
  durationSec Float?

  status      RecordingStatus @default(PENDING)

  // Auto-scoring bookkeeping
  autoScoredAt DateTime?
  autoPassed   Boolean?

  // --- QUALITY METRICS (Set by Python Worker) ---
  snrScore    Float?
  mosScore    Float?
  werScore    Float?
  transcript  String?

  // Aggregated NISQA mean of NOI/DIS/COL/LOUD
  meanScore   Float?

  // --- NISQA Quality Metrics (1-5) ---
  nisqaNoiPred  Float?
  nisqaDisPred  Float?
  nisqaColPred  Float?
  nisqaLoudPred Float?
  nisqaModel    String?

  // Review Data
  reviewedBy  String?
  reviewNote  String?

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  script      ScriptLine      @relation(fields: [scriptId], references: [id])

  @@index([status])
  @@index([userId, createdAt])
  @@index([scriptId, createdAt])
}
